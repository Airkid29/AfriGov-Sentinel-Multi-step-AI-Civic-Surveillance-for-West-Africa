# AfriGov Sentinel — Variables d'environnement
# Copie ce fichier en .env et remplis tes vraies valeurs

# Elastic Cloud
ELASTIC_URL=https://your-elastic-url
ELASTIC_API_KEY=your-elastic-api-key

# Elastic Agent Builder (Kibana → Search → Agents → ton agent → URL)
ELASTIC_AGENT_ID=your-agent-id

KIBANA_URL=https://your-kibana-url